# Session configuration
SESSION_SECRET=your-random-secret-key-change-this-in-production

# Google OAuth 2.0 credentials
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Steam OpenID configuration
# Get API key from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key
STEAM_RETURN_URL=http://localhost:3001/auth/steam/callback
STEAM_REALM=http://localhost:3001/

# Server configuration
PORT=3001
NODE_ENV=development
SERVER_HOST=localhost

# Admin configuration
# Email of the user who should have admin privileges
ADMIN_EMAIL=your-email@gmail.com

# Production URLs (update these for production)
# GOOGLE_CALLBACK_URL=https://stellaris-build.com/auth/google/callback
# STEAM_RETURN_URL=https://stellaris-build.com/auth/steam/callback
# STEAM_REALM=https://stellaris-build.com/
# NODE_ENV=production
# SERVER_HOST=your-production-domain.com
